{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/api/server.ts",
    "dev:seeded": "tsx scripts/dev-start.ts",
    "dev:full": "concurrently -n vite,server -c cyan,green \"npm run dev\" \"npm run dev:seeded\"",
    "build": "tsc -b && NODE_ENV=production vite build",
    "build:server": "tsc --noEmit -p tsconfig.server.json",
    "start": "tsx server/api/server.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:migrate": "tsx scripts/migrate.ts",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.1",
    "csv-parse": "^6.2.1",
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.4.2",
    "embedded-postgres": "^18.4.0-beta.17",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "pg-mem": "^3.0.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^4.3.1",
    "uuid": "^14.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
