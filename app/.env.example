# ─────────────────────────────────────────────────────────────────────────────
# SABIficate — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sabificate

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret key for signing JWTs (change in production!)
JWT_SECRET=your-jwt-secret-here

# Secret for signing cookies
COOKIE_SECRET=your-cookie-secret-here

# ── Redis ────────────────────────────────────────────────────────────────────
# Redis connection URL (used by rate limiter + BullMQ queues)
REDIS_URL=redis://localhost:6379

# ── Payments ─────────────────────────────────────────────────────────────────
# Paystack secret key (from dashboard.paystack.co)
PAYSTACK_SECRET_KEY=your-paystack-secret-key-here

# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Permanent access token from Meta Business
WHATSAPP_API_TOKEN=your-whatsapp-api-token-here

# Phone number ID from WhatsApp Business Manager
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here

# App secret for webhook signature verification
WHATSAPP_APP_SECRET=your-whatsapp-app-secret-here

# Verify token you set when registering the webhook with Meta
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token-here

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL for credential verification links etc.
APP_BASE_URL=http://localhost:5173

# Server port (Fastify)
PORT=3001

# Node environment: development | production | test
NODE_ENV=development

# Server log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# CORS allowed origin (set to your frontend URL in production)
CORS_ORIGIN=http://localhost:5173

# ── Vite (client-side) ──────────────────────────────────────────────────────
# API base URL used by the React frontend (must be prefixed with VITE_)
VITE_API_URL=/api/v1
